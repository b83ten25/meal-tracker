{
  "name": "meal-tracker",
  "version": "1.1.0",
  "description": "병원 직원 식대 관리 앱",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --publish always",
    "build:win": "electron-builder --win --publish always"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.hospital.meal-tracker",
    "productName": "식대관리",
    "files": [
      "index.html",
      "main.js"
    ],
    "mac": {
      "target": "dmg",
      "identity": null,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist",
      "hardenedRuntime": false
    },
    "publish": {
      "provider": "github",
      "owner": "b83ten25",
      "repo": "meal-tracker"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
